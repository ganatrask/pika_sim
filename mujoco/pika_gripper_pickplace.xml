<?xml version="1.0" encoding="utf-8"?>
<!--
  MuJoCo Pick-and-Place: Real Pika Gripper (STL meshes)
  Gripper mounted on 3-DOF Cartesian gantry, picking up a 2cm cube.

  REALISTIC: Gripper does NOT pass through the table.
  Collision filtering:
    - Group 1 (bit 1): gripper pads ↔ cube
    - Group 2 (bit 2): table/floor ↔ cube, table/floor ↔ gripper pads
  All collisions enabled so the gripper physically cannot penetrate the table.
-->
<mujoco model="pika_gripper_pickplace">
  <compiler angle="radian" meshdir="meshes" autolimits="true"/>

  <option gravity="0 0 -9.81" timestep="0.001" cone="elliptic" impratio="10"/>

  <default>
    <joint damping="0.5" armature="0.001"/>
    <geom contype="1" conaffinity="1" friction="1.5 0.005 0.0001" solref="0.008 1" solimp="0.95 0.99 0.001"/>
  </default>

  <asset>
    <mesh name="gripper_base_link" file="gripper_base_link.stl"/>
    <mesh name="gripper_left_link" file="gripper_left_link.stl"/>
    <mesh name="gripper_right_link" file="gripper_right_link.stl"/>

    <texture type="skybox" builtin="gradient" rgb1="0.4 0.6 0.8" rgb2="0.05 0.05 0.1" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.25 0.26 0.25" rgb2="0.18 0.18 0.18" markrgb="0.5 0.5 0.5" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="8 8" reflectance="0.1"/>
    <material name="cube_mat" rgba="0.9 0.15 0.15 1" specular="0.5" shininess="0.3"/>
    <material name="target_mat" rgba="0.2 0.9 0.2 0.3" specular="0.1"/>
    <material name="gripper_mat" rgba="0.85 0.85 0.9 1" specular="0.4" shininess="0.5"/>
    <material name="finger_mat" rgba="0.15 0.15 0.2 1" specular="0.1"/>
    <material name="gantry_mat" rgba="0.4 0.4 0.45 1" specular="0.2"/>
  </asset>

  <worldbody>
    <!-- Ground and table: collide with everything (contype=3, conaffinity=3) -->
    <geom name="floor" type="plane" size="1 1 0.01" material="groundplane"
          contype="3" conaffinity="3"/>
    <body name="table" pos="0 0 0.2">
      <geom name="table_top" type="box" size="0.3 0.2 0.01" rgba="0.55 0.45 0.35 1" mass="50"
            contype="3" conaffinity="3"/>
    </body>

    <!-- Lighting -->
    <light pos="0 0 1.5" dir="0 0 -1" diffuse="0.9 0.9 0.9" specular="0.3 0.3 0.3"/>
    <light pos="0.5 -0.4 1.0" dir="-0.4 0.3 -1" diffuse="0.3 0.3 0.3"/>

    <!-- Fixed scene cameras -->
    <camera name="overhead" pos="0 0 0.8" euler="0 0 0" fovy="60" resolution="640 480"/>
    <camera name="front" pos="0.4 -0.2 0.4" xyaxes="0.4 1 0 -0.2 0 1" fovy="50" resolution="640 480"/>

    <!-- Target placement zone (visual only) -->
    <body name="target_zone" pos="0.12 0 0.211">
      <geom name="target" type="cylinder" size="0.025 0.001" material="target_mat" contype="0" conaffinity="0"/>
    </body>

    <!-- 2cm cube: collides with table AND gripper pads -->
    <body name="cube" pos="-0.10 0 0.22">
      <joint name="cube_free" type="free"/>
      <inertial pos="0 0 0" mass="0.03" diaginertia="2e-7 2e-7 2e-7"/>
      <geom name="cube_geom" type="box" size="0.01 0.01 0.01" material="cube_mat"
            friction="5.0 0.05 0.01" solref="0.008 1"
            contype="3" conaffinity="3"/>
    </body>

    <!-- 3-DOF Cartesian Gantry -->
    <body name="gantry_x" pos="0 0 0.75">
      <joint name="slide_x" type="slide" axis="1 0 0" range="-0.25 0.25" damping="50" armature="0.05"/>
      <inertial pos="0 0 0" mass="0.5" diaginertia="1e-4 1e-4 1e-4"/>

      <body name="gantry_y">
        <joint name="slide_y" type="slide" axis="0 1 0" range="-0.15 0.15" damping="50" armature="0.05"/>
        <inertial pos="0 0 0" mass="0.3" diaginertia="1e-4 1e-4 1e-4"/>

        <body name="gantry_z">
          <joint name="slide_z" type="slide" axis="0 0 1" range="-0.4 0" damping="50" armature="0.05"/>
          <inertial pos="0 0 0" mass="0.3" diaginertia="1e-4 1e-4 1e-4"/>

          <!-- Wrist cameras moved to gripper_base_link body below -->

          <!-- Real Pika Gripper (rotated: local X → world -Z, pointing down) -->
          <body name="gripper_base_link" pos="0 0 -0.1" euler="0 1.5708 0">
            <inertial pos="0.037477 0 0.0084053" mass="0.18972"
                      diaginertia="0.0002159 0.00014308 0.00011036"/>
            <!-- IMU sensor site (co-located with gripper base center of mass) -->
            <site name="imu_site" pos="0.037477 0 0.0084053" size="0.005"/>
            <!-- Base mesh with collision enabled -->
            <geom name="gripper_base_vis" type="mesh" mesh="gripper_base_link" material="gripper_mat"
                  contype="3" conaffinity="3"/>

            <!-- ===== CAMERAS (mounted on gripper base) ===== -->
            <!-- Gripper local frame (rotated 90° around Y from world):
                 local +X = world -Z (down toward table)
                 local +Y = world +Y (left/right)
                 local +Z = world +X (forward)
                 Camera -Z axis = look direction. To look DOWN: euler="0 -1.5708 0"
                 Mesh rbound=0.079m, so cameras at local X < -0.09 clear the body -->

            <!-- Wrist cameras: between the fingers, looking down at workspace
                 gripper_base mesh extends X=0.0 to X=0.086 in body frame
                 Finger bodies at body X=0.0815, pads at X≈0.127
                 Camera at X=0.10: past the base mesh, between finger pads, centered (Y=0)
                 euler: camera -Z must align with body +X (world -Z = down) -->
            <!-- Wrist cameras: looking down at workspace with slight forward tilt
                 pos X=0.10: past gripper base mesh, between finger pads
                 euler Y=-1.5708: look straight down (body +X = world -Z)
                 euler Y=-1.85: ~18° forward tilt from straight down -->
            <camera name="color_left" pos="0.04 0.015 0.006" euler="0 -1.85 0"
                    fovy="87" resolution="640 480"/>
            <camera name="color_right" pos="0.04 -0.015 0.006" euler="0 -1.85 0"
                    fovy="87" resolution="640 480"/>
            <camera name="realsense_d405" pos="0.0710 0.0040 -0.0190" euler="0 -1.4790 0"
                    fovy="97" resolution="640 480"/>

            <!-- Left finger -->
            <body name="gripper_left_link" pos="0.0815 0.08851 0.0064182">
              <inertial pos="0.033255 -0.014661 -0.005761" mass="0.033674"
                        diaginertia="0.0000395 0.0000345 0.0000153"/>
              <joint name="gripper_left_joint" type="slide" axis="0 1 0" range="-0.05 0"
                     damping="0.1" armature="0.001"/>
              <!-- Finger mesh with collision enabled -->
              <geom name="gripper_left_vis" type="mesh" mesh="gripper_left_link" material="gripper_mat"
                    contype="3" conaffinity="3"/>
            </body>

            <!-- Right finger -->
            <body name="gripper_right_link" pos="0.0815 -0.088529 0.0064182">
              <inertial pos="0.033255 0.014661 -0.005811" mass="0.033674"
                        diaginertia="0.0000395 0.0000345 0.0000153"/>
              <joint name="gripper_right_joint" type="slide" axis="0 1 0" range="0 0.05"
                     damping="0.1" armature="0.001"/>
              <!-- Finger mesh with collision enabled -->
              <geom name="gripper_right_vis" type="mesh" mesh="gripper_right_link" material="gripper_mat"
                    contype="3" conaffinity="3"/>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <!-- Symmetric coupling: right = -left -->
  <equality>
    <joint joint1="gripper_right_joint" joint2="gripper_left_joint" polycoef="0 -1 0 0 0"/>
  </equality>

  <!-- Actuators -->
  <actuator>
    <position name="x_pos" joint="slide_x" kp="5000" ctrllimited="true" ctrlrange="-0.25 0.25"
              forcelimited="true" forcerange="-50 50"/>
    <position name="y_pos" joint="slide_y" kp="5000" ctrllimited="true" ctrlrange="-0.15 0.15"
              forcelimited="true" forcerange="-50 50"/>
    <position name="z_pos" joint="slide_z" kp="5000" ctrllimited="true" ctrlrange="-0.4 0"
              forcelimited="true" forcerange="-50 50"/>
    <position name="gripper_pos" joint="gripper_left_joint" kp="500" ctrllimited="true" ctrlrange="-0.05 0"
              forcelimited="true" forcerange="-20 20"/>
  </actuator>

  <!-- Sensors -->
  <sensor>
    <!-- Joint position sensors -->
    <jointpos name="x_sensor" joint="slide_x"/>
    <jointpos name="y_sensor" joint="slide_y"/>
    <jointpos name="z_sensor" joint="slide_z"/>
    <jointpos name="gripper_sensor" joint="gripper_left_joint"/>

    <!-- Joint velocity sensors -->
    <jointvel name="x_vel_sensor" joint="slide_x"/>
    <jointvel name="y_vel_sensor" joint="slide_y"/>
    <jointvel name="z_vel_sensor" joint="slide_z"/>
    <jointvel name="gripper_vel_sensor" joint="gripper_left_joint"/>

    <!-- Actuator force sensors (effort) -->
    <actuatorfrc name="x_force_sensor" actuator="x_pos"/>
    <actuatorfrc name="y_force_sensor" actuator="y_pos"/>
    <actuatorfrc name="z_force_sensor" actuator="z_pos"/>
    <actuatorfrc name="gripper_force_sensor" actuator="gripper_pos"/>

    <!-- IMU on gripper base: accelerometer + gyro -->
    <accelerometer name="imu_accel" site="imu_site" noise="0.01"/>
    <gyro name="imu_gyro" site="imu_site" noise="0.001"/>
    <framequat name="imu_orientation" objtype="site" objname="imu_site"/>

    <!-- Object tracking -->
    <framepos name="cube_pos" objtype="body" objname="cube"/>
  </sensor>
</mujoco>
